APP_NAME="Salonify"
APP_ENV=local
APP_KEY=base64:CHANGEZ_MOI_php_artisan_key_generate
APP_DEBUG=true
APP_TIMEZONE=Africa/Casablanca
APP_URL=http://localhost:8080

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ── Base de données ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=salonify
DB_USERNAME=root
DB_PASSWORD=

# ── Sessions & Cache ─────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=database

# ── Email ────────────────────────────────────────────────────
# En développement : log dans storage/logs/laravel.log
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@salonify.ma"
MAIL_FROM_NAME="Salonify"

# En production (exemple Gmail) :
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=votre@gmail.com
# MAIL_PASSWORD=votre_mot_de_passe_app
# MAIL_ENCRYPTION=tls

# ── Stockage fichiers ────────────────────────────────────────
FILESYSTEM_DISK=local

# ── SMS Twilio (rappels 24h / 2h) ────────────────────────────
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=your_auth_token
# TWILIO_FROM=+1XXXXXXXXXX

# ── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
